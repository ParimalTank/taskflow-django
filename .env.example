# Copy this to .env and fill in your values
# Get these from Supabase Dashboard > Project Settings > Database

SECRET_KEY=your-django-secret-key-here
DEBUG=True

# Supabase PostgreSQL connection
DATABASE_URL=postgres://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Supabase API (optional, for direct Supabase client usage)
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_KEY=your-supabase-anon-key
